# Database (Prisma schema uses MongoDB)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/finora?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
