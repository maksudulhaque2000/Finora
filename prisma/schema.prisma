generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum OrgType {
  FAMILY
  BUSINESS
  NGO
  PERSONAL
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AssetType {
  CASH
  BANK
  PROPERTY
  EQUIPMENT
  VEHICLE
  INVENTORY
  OTHER
}

enum LiabilityType {
  LOAN
  PAYABLE
  DUE
  OTHER
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String              @unique
  passwordHash  String?
  avatar        String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  memberships   OrganizationMember[]
  transactions  Transaction[]       @relation("CreatedTransactions")
  categories    Category[]          @relation("CreatedCategories")
  assets        Asset[]             @relation("CreatedAssets")
  liabilities   Liability[]         @relation("CreatedLiabilities")
  sessions      Session[]
}

model Organization {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  type         OrgType
  currency     String               @default("BDT")
  description  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  memberships  OrganizationMember[]
  categories   Category[]
  transactions Transaction[]
  assets       Asset[]
  liabilities  Liability[]
}

model OrganizationMember {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @db.ObjectId
  organizationId  String       @db.ObjectId
  role            MemberRole   @default(MEMBER)
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model Category {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            TransactionType
  color           String          @default("#d4a853")
  icon            String          @default("Circle")
  organizationId  String          @db.ObjectId
  createdById     String?         @db.ObjectId
  organization    Organization    @relation(fields: [organizationId], references: [id])
  createdBy       User?           @relation("CreatedCategories", fields: [createdById], references: [id])
  transactions    Transaction[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Transaction {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  type            TransactionType
  amount          Float
  description     String
  note            String?
  date            DateTime
  receiptUrl      String?
  categoryId      String          @db.ObjectId
  organizationId  String          @db.ObjectId
  createdById     String          @db.ObjectId
  paymentMethod   String?
  isRecurring     Boolean         @default(false)
  recurringRule   String?
  category        Category        @relation(fields: [categoryId], references: [id])
  organization    Organization    @relation(fields: [organizationId], references: [id])
  createdBy       User            @relation("CreatedTransactions", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId, date])
  @@index([categoryId, type])
}

model Asset {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            AssetType
  value           Float
  purchaseDate    DateTime?
  description     String?
  organizationId  String          @db.ObjectId
  createdById     String?         @db.ObjectId
  organization    Organization    @relation(fields: [organizationId], references: [id])
  createdBy       User?           @relation("CreatedAssets", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Liability {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            LiabilityType   @default(LOAN)
  principal       Float
  interestRate    Float           @default(0)
  monthlyInstallment Float?
  dueDate         DateTime?
  balance         Float
  description     String?
  organizationId  String          @db.ObjectId
  createdById     String?         @db.ObjectId
  organization    Organization    @relation(fields: [organizationId], references: [id])
  createdBy       User?           @relation("CreatedLiabilities", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime
}
